menu "RSS Display Configuration"

config WIFI_AP_SSID
    string "WiFi AP SSID"
    default "ESP32-Config"
    help
        SSID for the WiFi AP mode (config portal).

config WIFI_AP_PASSWORD
    string "WiFi AP Password"
    default "12345678"
    help
        Password for the WiFi AP mode. Must be at least 8 characters.

config WIFI_CONNECT_TIMEOUT_SEC
    int "WiFi connection timeout (seconds)"
    default 60
    range 10 300
    help
        Timeout for WiFi connection in STA mode.

config FIRMWARE_VERSION
    int "Firmware version"
    default 1
    help
        Firmware version number. Changing this will trigger NVS clear on next boot.

config RSS_URL
    string "RSS feed URL"
    default "http://192.168.3.107:1200/nytimes"
    help
        URL of the RSS feed to fetch.

config RSS_FETCH_INTERVAL_SEC
    int "RSS fetch interval (seconds)"
    default 300
    range 30 86400
    help
        Interval in seconds between RSS feed fetches.

endmenu
